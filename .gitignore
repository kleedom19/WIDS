# WiDS Datathon - Git Ignore File
# Exclude large files that exceed GitHub limits

# ============================================
# Large Cleaned Data Files (>100MB)
# ============================================
# These cleaned files are too large for GitHub
# Keep them locally, regenerate with clean_all_data.py

01_raw_data/cleaned/external_events_clean.csv
01_raw_data/cleaned/fire_perimeters_clean.csv
01_raw_data/cleaned/evac_zones_clean.csv
01_raw_data/cleaned/geo_events_clean.csv
01_raw_data/cleaned/external_changelog_clean.csv

# Alternatively, ignore entire cleaned folder
# 01_raw_data/cleaned/

